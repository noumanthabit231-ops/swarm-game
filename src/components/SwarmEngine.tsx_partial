export let ENGINE_STATE = 'MENU';

interface SwarmEngineProps {
  initialEmpire: {
    id: EmpireType;
    color: string;
  };
  onBack?: () => void;
  language: Language;
}

const SwarmEngine: React.FC<SwarmEngineProps> = ({ initialEmpire, onBack, language }) => {
  const t = translations[language];
  const playerColor = initialEmpire.color;
  
